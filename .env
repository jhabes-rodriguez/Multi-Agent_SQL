# ══════════════════════════════════════════════════════════════════
#  .env — Configuración centralizada del Orquestador Multi-Agent
#  El orquestador lee ESTE archivo y distribuye las keys correctas
#  a cada agente en su proceso hijo.
# ══════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────
# FALLBACK COMPARTIDO
# Si no defines keys individuales por agente, todos usarán estas.
# ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=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
GROQ_MODEL=llama-3.3-70b-versatile

# ──────────────────────────────────────────────────────────────────
# AGENTE 1 — Kaggle Scraper
# ──────────────────────────────────────────────────────────────────
AGENT1_GROQ_API_KEY=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
AGENT1_GROQ_MODEL=llama-3.3-70b-versatile
AGENT1_API_BASE_URL=http://localhost:8000
# Kaggle credentials (dejar vacío si no se usan)
AGENT1_KAGGLE_USERNAME=
AGENT1_KAGGLE_PASSWORD=
AGENT1_KAGGLE_COOKIE=

# ──────────────────────────────────────────────────────────────────
# AGENTE 2 — SQL Learner
# ──────────────────────────────────────────────────────────────────
AGENT2_GROQ_API_KEY=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
AGENT2_GROQ_MODEL=llama-3.3-70b-versatile
AGENT2_API_BASE_URL=http://localhost:8000

# ──────────────────────────────────────────────────────────────────
# AGENTE 3 — Visualizer (chat web)
# ──────────────────────────────────────────────────────────────────
AGENT3_GROQ_API_KEY=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
AGENT3_GROQ_MODEL=llama-3.3-70b-versatile
AGENT3_API_BASE_URL=http://localhost:8000
AGENT3_PORT=8080

# ──────────────────────────────────────────────────────────────────
# API CENTRAL (FastAPI)
# ──────────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000
PORT=8000
DATABASE_PATH=./data/multiagent.db
DATASETS_DIR=./data/datasets
CACHE_DB=./data/cache.db
